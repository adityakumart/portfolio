{
  "name": "portfolio",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "dev:web": "npx nx serve portfolio --hmr -o",
    "build": "nx build portfolio --configuration production && gzipper compress ./dist/apps/portfolio",
    "githubBuild": "nx build portfolio --configuration production && npx angular-cli-ghpages --dir=dist/apps/portfolio/browser",
    "build1": "nx build portfolio --configuration production --source-map && gzipper compress ./dist/apps/portfolio",
    "watch": "nx build portfolio --watch --configuration development",
    "test": "nx test portfolio",
    "serve:ssr:portfolio": "node dist/apps/portfolio/server/server.mjs",
    "dev:api": "npx nx serve portfolio-core"
  },
  "private": true,
