{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "types": ["node"],
    "skipLibCheck": true
  },
  "files": ["src/main.ts", "src/main.server.ts", "src/server.ts"],
  "include": [
    "src/**/*.d.ts",
    "src/**/*.ts"
  ],
  "exclude": ["src/**/*.spec.ts"],
  "angularCompilerOptions": {
    "extendedDiagnostics": {
      "checks": {
        "nullishCoalescingNotNullable": "suppress",
        "optionalChainNotNullable": "suppress"
      }
    }
  }
}
